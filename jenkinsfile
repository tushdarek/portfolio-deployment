pipeline {
    agent any

    environment {
        SSH_CRED = 'node-app-key'
        SERVER_IP = '172.31.44.241'
        REMOTE_USER = 'ubuntu'
        WEB_DIR = '/var/www/html'
    }

    stages {
        stage('Clone Repo') {
            steps {
                // Specify the correct branch (main instead of master)
                git branch: 'main', url: 'https://github.com/tushdarek/portfolio-deployment.git'
            }
        }
        
        stage('Deploy to Apache Server') {
            steps {
                sshagent(["${SSH_CRED}"]) {
                    sh '''
                        echo "Creating Apache directory if not exists..."
                        ssh -o StrictHostKeyChecking=no ${REMOTE_USER}@${SERVER_IP} sudo mkdir -p ${WEB_DIR}
                        
                        echo "Cleaning old files..."
                        ssh -o StrictHostKeyChecking=no ${REMOTE_USER}@${SERVER_IP} sudo rm -rf ${WEB_DIR}/*
                        
                        echo "Uploading files..."
                        scp -r README.md css fonts images index.html jenkinsfile js ${REMOTE_USER}@${SERVER_IP}:/tmp/
                        
                        echo "Deploying files..."
                        ssh -o StrictHostKeyChecking=no ${REMOTE_USER}@${SERVER_IP} sudo cp -r /tmp/* ${WEB_DIR}/
                        
                        echo "Attempting to restart Apache (if installed)..."
                        ssh -o StrictHostKeyChecking=no ${REMOTE_USER}@${SERVER_IP} "sudo systemctl restart apache2 || echo 'Apache not installed, skipping restart'"
                    '''
                }
            }
        }
    }
    
    post {
        success {
            echo 'Deployment completed successfully!'
        }
        failure {
            echo 'Deployment failed!'
        }
    }
}